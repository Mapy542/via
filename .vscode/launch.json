{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Via",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/via",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "QT_QPA_PLATFORM",
                    "value": "xcb"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake: Build",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Debug Via (lldb)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/via",
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
                "QT_QPA_PLATFORM": "xcb"
            },
            "preLaunchTask": "CMake: Build"
        }
    ]
}
